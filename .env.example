# Copy to .env.local (recommended) or .env
# Point FE to the same backend base URL as your Swagger
# Example:
#   VITE_API_BASE_URL=http://160.187.229.26:5002/api
VITE_API_BASE_URL=http://160.187.229.26:5002/api

# Optional: set explicitly if the backend exposes SignalR on a fixed route.
# If omitted, the app will try /hubs/chat, /api/hubs/chat, /chathub, and /chatHub.
VITE_CHAT_HUB_URL=http://160.187.229.26:5002/hubs/chat
